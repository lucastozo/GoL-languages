5 TEXT
10 HOME
20 LET BSIZE = 20
30 LET I = 0 : LET J = 0
35 LET COUNT = 0
40 DIM BOARD(BSIZE, BSIZE) : DIM NBOARD(BSIZE, BSIZE)
50 FOR I = 1 TO BSIZE
60   FOR J = 1 TO BSIZE
70    LET BOARD(I, J) = 0.5 < RND(1)
80   NEXT J
90 NEXT I
100 LET CHANGED = 0
110 GOSUB 2999
120 GOSUB 4999
125 HTAB 1 : VTAB 1
130 IF CHANGED = 1 THEN GOTO 100
140 END

2999 REM PRINT BOARD SUBROUTINE
3000 FOR I = 1 TO BSIZE
3010  FOR J = 1 TO BSIZE
3020   IF BOARD(I, J) = 1 THEN PRINT CHR$(127);
3030   IF BOARD(I, J) = 0 THEN PRINT ".";
3040  NEXT J
3050  PRINT ""
3060 NEXT I
3070 RETURN

3999 REM COUNT ALIVE NEIGHBORS SUBROUTINE
4000 LET COUNT = 0
4010 FOR X = -1 TO 1
4020   FOR Y = -1 TO 1
4030     IF X = 0 AND Y = 0 THEN GOTO 4090
4040     LET NI = I + X
4050     LET NJ = J + Y
4060     IF NI < 1 OR NI > BSIZE OR NJ < 1 OR NJ > BSIZE THEN GOTO 4090
4070     IF BOARD(NI, NJ) = 1 THEN LET COUNT = COUNT + 1
4090   NEXT Y
4100 NEXT X
4110 RETURN

4999 REM COMPUTE NEXT GENERATION SUBROUTINE
5010 FOR I = 1 TO BSIZE
5020    FOR J = 1 TO BSIZE
5030        GOSUB 3999
5040        IF BOARD(I, J) = 1 THEN LET NBOARD(I, J) = (COUNT = 2) OR (COUNT = 3)
5050        IF BOARD(I, J) = 0 THEN LET NBOARD(I, J) = (COUNT = 3)
5060        IF NBOARD(I, J) <> BOARD(I, J) THEN LET CHANGED = 1
5070    NEXT J
5080 NEXT I
5090 FOR I = 1 TO BSIZE
5100   FOR J = 1 TO BSIZE
5110    LET BOARD(I, J) = NBOARD(I, J)
5120  NEXT J
5130 NEXT I
5140 RETURN